# ============================
# .gitignore for Selenium + Maven + Cucumber Framework
# ============================

# -------- Maven --------
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# -------- IDE: IntelliJ IDEA --------
.idea/
*.iml
*.iws
*.ipr
out/

# -------- IDE: Eclipse --------
.classpath
.project
.settings/
bin/

# -------- IDE: VS Code --------
.vscode/

# -------- OS Files --------
.DS_Store
Thumbs.db
desktop.ini

# -------- Logs --------
*.log
logs/

# -------- Test Output / Reports --------
target/
test-output/
allure-results/
allure-report/
cucumber-reports/
screenshots/

# -------- Rerun files --------
rerun.txt
failed_scenarios.txt

# -------- Sensitive Data --------
*.env
**/config/local.properties
**/secrets/

# -------- Compiled --------
*.class
*.jar
*.war